<Window x:Class="Tema1.ScoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rezultate" Height="450" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="30" VerticalAlignment="Center">
        <TextBlock Text="🏆 Felicitări!" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#f1c40f"/>

        <Border Background="#ecf0f1" CornerRadius="10" Padding="20" Margin="0,20">
            <Label x:Name="lblScor" Content="Scor: 0" FontSize="24" HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>

        <DataGrid x:Name="dgScoruri" Height="150" Margin="0,10" 
              AutoGenerateColumns="True" 
              Background="Transparent" 
              BorderThickness="1" 
              RowBackground="White" 
              AlternatingRowBackground="#f9f9f9"/>

        <Button x:Name="btnRestart" Content="JOACĂ DIN NOU" Background="#2980b9" Click="btnRestart_Click"/>
    </StackPanel>
</Window>