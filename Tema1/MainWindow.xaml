<Window x:Class="Tema1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quiz Trivia" Height="450" Width="600" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.Background>
            <SolidColorBrush Color="#f5f6fa"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ProgressBar x:Name="pbProgres" Grid.Row="0" Height="15" Foreground="#2ecc71" Background="#dcdde1" BorderThickness="0"/>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Margin="0,20" Padding="20">
            <TextBlock x:Name="TextBlockIntrebare" FontSize="22" FontWeight="SemiBold" TextAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#2f3640"/>
        </Border>

        <UniformGrid Grid.Row="2" Columns="2" Rows="2" Margin="10">

            <RadioButton x:Name="rbA" GroupName="Quiz" Style="{StaticResource KahootButtonStyle}" 
                 Background="#E21B3C" Content="Varianta A"/>

            <RadioButton x:Name="rbB" GroupName="Quiz" Style="{StaticResource KahootButtonStyle}" 
                 Background="#1368CE" Content="Varianta B"/>

            <RadioButton x:Name="rbC" GroupName="Quiz" Style="{StaticResource KahootButtonStyle}" 
                 Background="#D89E00" Content="Varianta C"/>

            <RadioButton x:Name="rbD" GroupName="Quiz" Style="{StaticResource KahootButtonStyle}" 
                 Background="#26890C" Content="Varianta D"/>

        </UniformGrid>

        <Button x:Name="btnNext" Grid.Row="3" Content="Următoarea Întrebare →" Height="50" FontSize="18" FontWeight="Bold" Background="#8e44ad" Click="btnNext_Click"/>
    </Grid>
</Window>